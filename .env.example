# Required — database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp
DB_USER=postgres
DB_PASSWORD=secret

# Optional — override default paths
# Defaults are relative to the directory where you run pgmigrate (project root):
#   migrations/ and schemas/ next to your .env file
# Use absolute paths when overriding to avoid ambiguity.
# MIGRATIONS_DIR=/absolute/path/to/migrations
# SCHEMAS_DIR=/absolute/path/to/schemas
